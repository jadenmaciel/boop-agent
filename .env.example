PORT=3456
BOOP_OWNER_NUMBER=+15550000000
BOOP_CONFIRMATION_HMAC_SECRET=replace-with-at-least-32-random-characters
BOOP_DATABASE_PATH=/var/lib/boop/boop.db
BOOP_VAULT_ROOT=/srv/boop/personal
BOOP_READ_ONLY_DIR=/var/lib/boop/read-only-reasons

SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=+15550000001
PUBLIC_URL=https://boop.example.com

BOOP_CODEX_AUTH_HOME=/var/lib/boop/codex
BOOP_CODEX_MODEL=gpt-5.5
BOOP_CODEX_REASONING_EFFORT=medium

COMPOSIO_API_KEY=
COMPOSIO_USER_ID=boop-owner
BOOP_COMPOSIO_POLICY_JSON='{"gmail":{"read":["GMAIL_FETCH_EMAILS","GMAIL_FETCH_MESSAGE_BY_MESSAGE_ID","GMAIL_GET_PROFILE"],"write":["GMAIL_SEND_EMAIL","GMAIL_REPLY_TO_THREAD","GMAIL_CREATE_EMAIL_DRAFT"],"scopes":["https://www.googleapis.com/auth/gmail.readonly","https://www.googleapis.com/auth/gmail.modify","https://www.googleapis.com/auth/gmail.send"]},"googlecalendar":{"read":["GOOGLECALENDAR_LIST_EVENTS","GOOGLECALENDAR_FIND_EVENT"],"write":["GOOGLECALENDAR_CREATE_EVENT","GOOGLECALENDAR_UPDATE_EVENT","GOOGLECALENDAR_DELETE_EVENT","GOOGLECALENDAR_RSVP_EVENT"],"scopes":["https://www.googleapis.com/auth/calendar.readonly","https://www.googleapis.com/auth/calendar.events"]}}'

BOOP_BROWSER_ENABLED=true
BOOP_BROWSER_PROFILE_DIR=/var/lib/boop/browser-profile
BOOP_BROWSER_SHOW_UI=false
BOOP_BROWSER_LOGIN_HANDOFF=true
BOOP_BROWSER_ALLOWED_DOMAINS=
BOOP_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
